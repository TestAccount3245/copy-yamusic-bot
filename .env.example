# Telegram
BOT_TOKEN=your_bot_token_here
MINIAPP_URL=https://your-miniapp-domain.com

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/yamusic

# Redis
REDIS_URL=redis://redis:6379/0

# Storage
UPLOAD_MAX_SIZE_MB=50
STORAGE_PATH=storage
CACHE_TTL_HOURS=24

# Rate limits
DOWNLOADS_PER_HOUR=30
UPLOADS_PER_DAY=10

# CORS — GitHub Pages + tunnel (через запятую)
# Пример: CORS_ORIGINS=https://youruser.github.io,https://xxx.trycloudflare.com
CORS_ORIGINS=
